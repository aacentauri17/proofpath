# Copy this file to .env and fill in your values. .env is git-ignored - never commit it.
# Used only by tools/sync-catalog.js to push the catalog to Supabase.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# The SECRET (service) key from Supabase - Project Settings > API Keys.
# Catalog writes bypass row-level security, so the secret key is required here.
# This must stay private. Do NOT put it in index.html or commit it.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
